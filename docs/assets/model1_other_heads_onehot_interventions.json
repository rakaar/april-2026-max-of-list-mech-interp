  "condition_definitions": {
    "H3 max one-hot": "Replace only H3's ANS row by one-hot to a max-token position.",
    "H0/H2 top + H3 max one-hot": "Replace H0 and H2 by one-hot to their actual top key; replace H3 by one-hot to a max-token position; keep H1 actual.",
    "all heads top one-hot": "Replace each head by one-hot to that head's actual top key.",
    "H0/H2/H3 max one-hot": "Replace H0, H2, and H3 by one-hot to a max-token position; keep H1 actual.",
    "all heads max one-hot": "Force every head to one-hot attend to a max-token position.",
    "only H3 max one-hot": "Ablate H0 and H2, keep H1 actual, and replace H3 by one-hot to a max-token position."
  }
